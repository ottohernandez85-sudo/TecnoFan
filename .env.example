# PostgreSQL (local o Supabase). En Supabase añade ?sslmode=require si hace falta.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

PORT=4000

# URL pública del frontend (Vercel), sin barra final. Obligatoria en producción para CORS.
CLIENT_URL=https://tu-app.vercel.app

# Orígenes extra separados por coma (p. ej. deploy previews de Vercel).
# CLIENT_URLS=https://tu-app-git-main-usuario.vercel.app

JWT_SECRET="change-me-in-production-use-long-random-string"

UPLOAD_DIR=uploads

# Opcional: NODE_ENV=production
