# =============================================================================
# GUÍA DE DESPLIEGUE — copia este archivo a .env.deploy.local y rellénalo.
#   cp .env.deploy.local.example .env.deploy.local
# .env.deploy.local está en .gitignore y NO se sube a Git.
# =============================================================================
#
# Este archivo es solo tu “bloc de notas” con URLs y cadenas que copiarás
# a los paneles de Supabase, Render y Vercel. Los servicios NO leen este
# archivo automáticamente: tú pegas cada valor donde indica cada paso.
#
# ---------------------------------------------------------------------------
# 1) SUPABASE (base de datos PostgreSQL)
# ---------------------------------------------------------------------------
# Dónde: https://supabase.com/dashboard → tu proyecto
#
# Paso A — Connection string (para Render, variable DATABASE_URL)
#   Settings → Database → Connection string → pestaña URI (o “Nodejs”)
#   Copia la URI completa (incluye contraseña). A veces hace falta
#   ?sslmode=require al final si Prisma falla al conectar.
#
# Paso B — (opcional) anotar el ref del proyecto para abrir el panel rápido
#
# Pega aquí SOLO para tu referencia local (luego la misma cadena va en Render):
DATABASE_URL=

# Opcional, solo referencia:
# SUPABASE_PROJECT_REF=

# ---------------------------------------------------------------------------
# 2) RENDER (backend Node / API)
# ---------------------------------------------------------------------------
# Dónde: https://dashboard.render.com → tu Web Service o el creado por Blueprint
#
# Qué sacar DESPUÉS del primer deploy exitoso:
#   En la página del servicio, arriba: la URL pública, p.ej.
#   https://tecnofan-api.onrender.com
#   (sin barra final). La usarás en Vercel.
#
RENDER_API_PUBLIC_URL=

# Qué PONER en Render (Environment → Environment Variables del servicio):
#   DATABASE_URL     = la misma cadena que guardaste arriba (desde Supabase)
#   JWT_SECRET       = inventa una cadena larga aleatoria (no la compartas)
#   CLIENT_URL       = URL de producción de Vercel (paso 3), https://… sin /
#   CLIENT_URLS      = (opcional) otras URLs de preview de Vercel, separadas por coma
#   NODE_ENV         = production
#   UPLOAD_DIR       = uploads
#   PORT             = lo asigna Render solo; no hace falta definirla a mano
#
# ---------------------------------------------------------------------------
# 3) VERCEL (frontend estático / Vite)
# ---------------------------------------------------------------------------
# Dónde: https://vercel.com → tu proyecto → Settings → Environment Variables
#        y también la URL en “Domains” o al abrir el deployment.
#
# Qué sacar después del deploy:
#   URL de producción, p.ej. https://tecnofan.vercel.app  (sin barra final)
#
VERCEL_PRODUCTION_URL=

# Qué PONER en Vercel (Environment Variables, entorno Production):
#   VITE_API_URL =  RENDER_API_PUBLIC_URL + "/api"
#   Ejemplo: si Render es https://foo.onrender.com entonces:
#   VITE_API_URL=https://foo.onrender.com/api
#
VITE_API_URL=

# ---------------------------------------------------------------------------
# 4) Orden recomendado (evita errores de CORS y URL mal puesta)
# ---------------------------------------------------------------------------
#   1. Supabase: copia DATABASE_URL → Render (variable DATABASE_URL).
#   2. Render: despliega; copia la URL del servicio → rellena RENDER_API_PUBLIC_URL
#      y construye VITE_API_URL = esa URL + "/api".
#   3. Vercel: crea proyecto, pon VITE_API_URL, despliega; copia URL del front
#      → VERCEL_PRODUCTION_URL y la misma en Render como CLIENT_URL.
#   4. Render: redeploy si cambiaste CLIENT_URL para que CORS acepte el front.
#
# ---------------------------------------------------------------------------
# 5) GitHub (opcional, solo para push desde tu máquina)
# ---------------------------------------------------------------------------
# Ya tienes .github-push.env con GITHUB_TOKEN para ./scripts/push-tecnofan.sh
# No hace falta duplicar el token aquí.
